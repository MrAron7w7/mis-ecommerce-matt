// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
}

////////////////////
/// ENUMS
////////////////////

enum Role {
  USER
  SELLER
  ADMIN
}

enum OrderStatus {
  PENDING
  ACCEPTED
  REJECTED
}

////////////////////
/// USERS
////////////////////

model User {
  id              BigInt    @id @default(autoincrement())
  name            String
  email           String    @unique
  emailVerifiedAt DateTime?
  password        String
  rememberToken   String?
  role            Role      @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reviews  Review[]
  carts    Cart[]
  orders   Order[]
  sessions Session[]
}

////////////////////
/// AUTH / SYSTEM
////////////////////

model PasswordResetToken {
  email     String    @id
  token     String
  createdAt DateTime?
}

model Session {
  id           String  @id
  userId       BigInt?
  ipAddress    String?
  userAgent    String?
  payload      String  @db.LongText
  lastActivity Int

  user User? @relation(fields: [userId], references: [id])
}

////////////////////
/// CACHE & JOBS
////////////////////

model Cache {
  key        String @id
  value      String @db.MediumText
  expiration Int
}

model CacheLock {
  key        String @id
  owner      String
  expiration Int
}

model Job {
  id          BigInt @id @default(autoincrement())
  queue       String
  payload     String @db.LongText
  attempts    Int
  reservedAt  Int?
  availableAt Int
  createdAt   Int
}

model JobBatch {
  id           String  @id
  name         String
  totalJobs    Int
  pendingJobs  Int
  failedJobs   Int
  failedJobIds String  @db.LongText
  options      String? @db.MediumText
  cancelledAt  Int?
  createdAt    Int
  finishedAt   Int?
}

model FailedJob {
  id         BigInt   @id @default(autoincrement())
  uuid       String   @unique
  connection String
  queue      String
  payload    String   @db.LongText
  exception  String   @db.LongText
  failedAt   DateTime @default(now())
}

model PersonalAccessToken {
  id            BigInt    @id @default(autoincrement())
  tokenableType String
  tokenableId   BigInt
  name          String
  token         String    @unique
  abilities     String?
  lastUsedAt    DateTime?
  expiresAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

////////////////////
/// CATALOG
////////////////////

model Category {
  id       BigInt  @id @default(autoincrement())
  name     String  @unique
  slug     String  @unique
  imageUrl String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model Supplier {
  id       BigInt  @id @default(autoincrement())
  name     String
  email    String? @unique
  phone    String?
  address  String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model Product {
  id          BigInt  @id @default(autoincrement())
  name        String  @unique
  slug        String  @unique
  description String?
  price       Decimal @db.Decimal(10, 2)
  stock       Int     @default(0)
  isActive    Boolean @default(true)
  imageUrl    String?

  categoryId BigInt
  supplierId BigInt?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  supplier Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  variants   ProductVariant[]
  reviews    Review[]
  cartItems  CartItem[]
  orderItems OrderItem[]
}

model ProductVariant {
  id    BigInt @id @default(autoincrement())
  type  String
  value String

  productId BigInt

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([type, value, productId])
}

////////////////////
/// REVIEWS
////////////////////

model Review {
  id         BigInt  @id @default(autoincrement())
  userId     BigInt
  productId  BigInt
  rating     Int
  comment    String?
  isVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

////////////////////
/// CART
////////////////////

model Cart {
  id     BigInt  @id @default(autoincrement())
  userId BigInt
  total  Decimal @default(0) @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
}

model CartItem {
  id         BigInt  @id @default(autoincrement())
  cartId     BigInt
  productId  BigInt
  quantity   Int
  unitPrice  Decimal @db.Decimal(10, 2)
  totalPrice Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
}

////////////////////
/// ORDERS
////////////////////

model Order {
  id                String      @id @default(uuid())
  orderNumber       String      @unique
  userId            BigInt
  status            OrderStatus @default(PENDING)
  total             Decimal     @db.Decimal(10, 2)
  shippingAddress   String
  paymentMethod     String?
  paymentReceiptUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]
}

model OrderItem {
  id         BigInt  @id @default(autoincrement())
  orderId    String
  productId  BigInt
  quantity   Int
  unitPrice  Decimal @db.Decimal(10, 2)
  totalPrice Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

////////////////////
/// SETTINGS
////////////////////

model FooterSetting {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NavbarSetting {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuthBackground {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ColorPalette {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BannerAndImage {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PaymentConfig {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
